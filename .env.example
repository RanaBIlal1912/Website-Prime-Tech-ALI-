# Root compose environment. Copy to .env and fill real values for production.
# NEVER commit the real .env.

# --- Postgres ---
POSTGRES_USER=primetech
POSTGRES_PASSWORD=use-a-strong-password
POSTGRES_DB=primetech

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.prod
DEBUG=False
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=replace-with-50+-random-chars
# JWT signing key must be >= 32 bytes.
JWT_SIGNING_KEY=replace-with-32+-random-bytes
ALLOWED_HOSTS=primetech.pk,www.primetech.pk
CORS_ALLOWED_ORIGINS=https://primetech.pk
CSRF_TRUSTED_ORIGINS=https://primetech.pk
TIME_ZONE=Asia/Karachi

# --- First-run seeding (set true once, then back to false) ---
RUN_SEED=false
SEED_ADMIN_EMAIL=admin@primetech.pk
# If omitted, a strong password is generated and printed once in the logs.
SEED_ADMIN_PASSWORD=

# --- HTTPS hardening (prod) ---
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# --- Media storage: local | s3 | r2 | spaces | gcs | azure ---
MEDIA_STORAGE_BACKEND=local
# For s3/r2/spaces:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_ENDPOINT_URL=        # R2/Spaces endpoint
# AWS_S3_REGION_NAME=

# --- Email (transactional) ---
# EMAIL_HOST=
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=no-reply@primetech.pk
