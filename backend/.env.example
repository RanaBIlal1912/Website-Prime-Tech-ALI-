# Copy to backend/.env for local dev. NEVER commit real secrets.
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-to-a-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=Asia/Karachi

# Database (PostgreSQL)
DATABASE_URL=postgres://primetech:primetech@localhost:5432/primetech

# JWT
JWT_SIGNING_KEY=change-me-too
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# Login lockout
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# CORS / CSRF (frontend origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Media storage: local | s3 | r2 | spaces | gcs | azure
MEDIA_STORAGE_BACKEND=local
